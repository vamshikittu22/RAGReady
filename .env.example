# RAGReady Configuration
# Copy this file to .env and fill in your values

# Google Gemini API key (for generation)
RAGREADY_GOOGLE_API_KEY=

# Embedding model (default: sentence-transformers/all-MiniLM-L6-v2)
RAGREADY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking parameters
RAGREADY_CHUNK_SIZE=512
RAGREADY_CHUNK_OVERLAP=50

# Retrieval parameters
RAGREADY_DENSE_TOP_K=20
RAGREADY_SPARSE_TOP_K=20
RAGREADY_RRF_K=60
RAGREADY_FINAL_TOP_K=5

# Generation parameters
RAGREADY_CONFIDENCE_THRESHOLD=0.6
RAGREADY_TEMPERATURE=0.1

# Storage paths
RAGREADY_CHROMA_PERSIST_DIR=./data/indexes/chroma
RAGREADY_BM25_PERSIST_PATH=./data/indexes/bm25_index.pkl
